# ── Deployer ────────────────────────────────────────────────────────────────
# Private key of the wallet used to deploy contracts (no 0x prefix needed)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# ── RPC providers ────────────────────────────────────────────────────────────
# Get from https://dashboard.alchemy.com/
ALCHEMY_API_KEY=your_alchemy_api_key_here

# ── Block explorer API keys ──────────────────────────────────────────────────
# Etherscan  → https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Polygonscan → https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# ── Gas reporting ────────────────────────────────────────────────────────────
# Set to "true" to enable gas cost reporting during tests
REPORT_GAS=false

# CoinMarketCap key for USD pricing in gas reports
# Get from https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here
