# ═══════════════════════════════════════════════════════════════════════════
# ChainEstate — copy this file to .env and adjust values
#   cp .env.example .env
#
# Used by: docker compose (recommended) and local dev
# NEVER commit .env — it is listed in .gitignore
# ═══════════════════════════════════════════════════════════════════════════

# ── Docker host ports (optional) ─────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=3001
MONGO_PORT=27017

# ── Frontend (browser-facing URLs — use localhost when running via Docker) ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_CONTRACT_ADDRESS=

# ── Backend ─────────────────────────────────────────────────────────────────
PORT=3001
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
FRONTEND_ORIGIN=http://localhost:3000

# Local dev only (Docker Compose overrides this to mongodb://mongodb:27017/…)
MONGODB_URI=mongodb://localhost:27017/chainestate

# ── Blockchain — Sepolia (optional) ─────────────────────────────────────────
SEPOLIA_RPC_URL=
PRIVATE_KEY=
CONTRACT_ADDRESS=

# ── Hardhat / contract deploy (root contracts/) ───────────────────────────────
DEPLOYER_PRIVATE_KEY=
ALCHEMY_API_KEY=
ETHERSCAN_API_KEY=
