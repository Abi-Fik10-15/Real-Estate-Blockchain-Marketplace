# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/chainestate
# Optional: force zero-install local dev DB. Data resets when the API stops.
MONGODB_USE_MEMORY=false

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=chainestate-dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000

# ── Blockchain (Sepolia — optional for local dev) ───────────────────────────
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
PRIVATE_KEY=0x_YOUR_DEPLOYER_WALLET_PRIVATE_KEY
CONTRACT_ADDRESS=0x_YOUR_DEPLOYED_CONTRACT_ADDRESS

# Hardhat deploy (npm run contracts:deploy:sepolia)
DEPLOYER_PRIVATE_KEY=
ALCHEMY_API_KEY=
ETHERSCAN_API_KEY=

# ── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
